{
  "name": "claude-feishu-bridge",
  "version": "1.0.0",
  "description": "Bridge service for Claude Code and Feishu integration",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node scripts/kill-port.js && node src/index.js",
    "dev": "node scripts/kill-port.js && node --watch src/index.js",
    "mcp": "node src/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "stop:pm2": "pm2 stop claude-feishu-bridge",
    "restart:pm2": "pm2 restart claude-feishu-bridge",
    "logs:pm2": "pm2 logs claude-feishu-bridge",
    "status:pm2": "pm2 status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^10.5.0",
    "js-yaml": "^4.1.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
