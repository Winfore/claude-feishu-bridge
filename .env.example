# 飞书应用配置
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# Anthropic API 配置
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Anthropic API 地址（可选，默认使用官方地址）
# 如果使用代理或自定义端点，取消注释并修改
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Claude 模型（可选，默认 claude-opus-4-20250514）
# CLAUDE_MODEL=claude-opus-4-20250514

# 会话超时时间（可选，默认 30 分钟 = 1800000 毫秒）
# SESSION_TIMEOUT=1800000

# 工作空间根目录（所有项目都在此目录下）
WORKSPACE_ROOT=D:/project

# 长连接模式： 无需公网域名和内网穿透！
# 可选： 适SDK不需要以下配置
# FEISHU_ENCRYPT_KEY=xxxxxxxx
# FEISHU_VERIFICATION_TOKEN=xxxxxxxx

# 桥接服务配置
BRIDPORT=3100GE_
BRIDGE_HOST=localhost

# 安全配置
# 多个用户用逗号分隔，留空则允许所有用户
ALLOWED_USERS=
ADMIN_USERS=admin_user_id

# 通知配置
# 用于 feishu_notify 工具的默认目标群
NOTIFY_CHAT_ID=oc_xxxxxxxxxxxx
